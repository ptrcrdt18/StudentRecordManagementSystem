<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Header with color -->
    <VBox style="-fx-background-color: #2c3e50; -fx-padding: 15;">
        <Label text="📚 STUDENT RECORDS SYSTEM" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" alignment="CENTER"/>
        <Label text="Manage Student Information" style="-fx-text-fill: #bdc3c7; -fx-font-size: 14px;" alignment="CENTER"/>
    </VBox>

    <!-- Form Fields in Grid -->
    <GridPane hgap="15" vgap="10" style="-fx-padding: 20; -fx-background-color: #ecf0f1; -fx-border-radius: 5;">
        <padding>
            <Insets top="15" right="15" bottom="15" left="15"/>
        </padding>

        <Label text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtName" promptText="Enter student name" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250"/>

        <Label text="Course/Program:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtCourse" promptText="Enter course" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="250"/>

        <Label text="Year Level:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
        <ChoiceBox fx:id="cbYear" prefWidth="150" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <!-- Buttons -->
        <HBox spacing="15" GridPane.columnIndex="1" GridPane.rowIndex="3">
            <Button text="➕ ADD" onAction="#addStudent" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="80"/>
            <Button text="✏️ UPDATE" onAction="#updateStudent" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="80"/>
            <Button text="🗑 DELETE" onAction="#deleteStudent" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="80"/>
            <Button text="🔄 CLEAR" onAction="#clearFields" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="80"/>
        </HBox>
    </GridPane>

    <!-- Table -->
    <TableView fx:id="table" prefHeight="300" style="-fx-border-color: #bdc3c7;">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colName" text="Student Name" prefWidth="250"/>
            <TableColumn fx:id="colCourse" text="Course" prefWidth="200"/>
            <TableColumn fx:id="colYear" text="Year" prefWidth="100"/>
        </columns>
    </TableView>

    <!-- Status Bar -->
    <Label text="✅ Ready" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
</VBox>